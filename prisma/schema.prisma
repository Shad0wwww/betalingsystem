generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model User {
    id           String @id @default(uuid())
    name         String
    email        String @unique
    phone        String @unique
    phoneCountry String @default("DK")
    role         Role   @default(USER)

    reservedBalance Float @default(0)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    stripeCustomerId String? @unique

    //Relationer
    verificationTokens VerificationToken[]
    invoices           Invoice[]
    boats              Boat[]
    transactions       Transaction[]
    auditLogs          AuditLog[]
    meterSessions      MeterSession[]
}

model AuditLog {
    id        String     @id @default(cuid())
    userId    String
    user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
    action    ActionType
    details   String?
    timestamp DateTime   @default(now())
}

model VerificationToken {
    identifier String   @unique
    token      String   @unique
    expires    DateTime

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([identifier, token])
}

model Invoice {
    id     Int    @id @default(autoincrement())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    InvoiceNumber String? @unique

    amount   Int
    currency String        @default("dkk")
    status   InvoiceStatus @default(PENDING)

    type UtilityType

    stripeSessionId       String? @unique
    stripePaymentIntentId String? @unique

    dueDate   DateTime
    paidAt    DateTime?
    createdAt DateTime  @default(now())
}

model Boat {
    id     Int    @id @default(autoincrement())
    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    kaldeNavn String
    skibModel String

    meterSessions MeterSession[]
}

model MeterSession {
    id Int @id @default(autoincrement())

    // Brug meterId (intern database ID) til relationen, ikke Modbus deviceID
    meterId Int
    meter   Meter @relation(fields: [meterId], references: [id])

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    boatId Int
    boat   Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)

    type UtilityType

    startValue Float
    endValue   Float?

    startTime DateTime  @default(now())
    endTime   DateTime?
    isActive  Boolean   @default(true)

    readings MeterReading[]
}

model MeterReading {
    id Int @id @default(autoincrement())

    meterId Int
    meter   Meter @relation(fields: [meterId], references: [id])

    type  UtilityType
    value Float
    date  DateTime    @default(now())

    sessionId Int?
    session   MeterSession? @relation(fields: [sessionId], references: [id])

    @@index([meterId, date])
}

model Meter {
    id       Int         @id @default(autoincrement())
    deviceId String         @unique // Modbus ID (Kan nu ændres uden at smadre historik!)
    type     UtilityType
    location String?
    status   MeterStatus @default(INACTIVE)

    sessions MeterSession[]
    readings MeterReading[]
}

model Transaction {
    id     Int    @id @default(autoincrement())
    userId String
    user   User   @relation(fields: [userId], references: [id])

    amount Float           @default(0)
    type   TransactionType

    stripeSessionId String? @unique

    createdAt DateTime @default(now())
}

enum TransactionType {
    PAID
    REFUND
    RESERVED
    RESERVATION_RELEASED
}

enum InvoiceStatus {
    PENDING
    PAID
    FAILED
    OVERDUE
}

enum UtilityType {
    WATER
    ELECTRICITY
}

enum Role {
    USER
    ADMIN
}

enum ActionType {
    LOGIN
    LOGOUT
    EMAIL_CHANGE
    RESERVED_BALANCE
    PAYMENT_MADE
    PAYMENT_FAILED
    BOAT_ADDED
    BOAT_REMOVED
    LINKED_STRIPE
    NAME_CHANGE
    EMAIL_SEND_OTP_SUCCESS
    EMAIL_SEND_OTP_FAILED
    PAYMENT_LINK_CREATED
    LOGIN_OTP_SENT
    CREATE_METER
    UPDATE_METER
    DELETE_METER
    LOGIN_OTP_SENT_SUCCESS

    CONNECTED_METER
    DISCONNECTED_METER
}

enum MeterStatus {
    ACTIVE
    INACTIVE
    MAINTENANCE
}